# ════════════════════════════════════════════════════════════════════════════
# Swadyum environment variables — copy to .env.local and fill in real values.
# NEVER commit .env.local. (V10)
# ════════════════════════════════════════════════════════════════════════════

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://dligrptvajjsbzlcpjsk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_BASE_URL=http://localhost:3001/api
VITE_PICKUP_LOCATION=Primary

# ─── Database (admin/migration scripts only) ─────────────────────────────────
# Direct Postgres connection used by execute_sql.cjs / frontend/*.js helper
# scripts. Get it from Supabase → Project Settings → Database → Connection string
# (URI). NEVER commit this — it goes in .env.local only.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.dligrptvajjsbzlcpjsk.supabase.co:5432/postgres

# ─── Backend (server.js) ──────────────────────────────────────────────────────
PROXY_PORT=3001

# Razorpay (V11). Leave unset in dev to use MOCK_PAYMENTS.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Set to "true" ONLY in local dev to accept mock payments.
MOCK_PAYMENTS=false

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary

# Fastrr / Shiprocket Checkout
FASTRR_API_KEY=
FASTRR_SECRET_KEY=
# Set to "true" ONLY in local dev to accept unsigned webhooks.
MOCK_WEBHOOKS=false

# Supabase (server-side catalog sync)
VITE_SUPABASE_URL=https://dligrptvajjsbzlcpjsk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public store URL (used as the default Fastrr redirect, V16)
PUBLIC_STORE_URL=https://swadyum.store

# ─── Supabase Edge Functions (set via `supabase secrets set`) ─────────────────
# whatsapp-auth
SUPABASE_URL=https://dligrptvajjsbzlcpjsk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-project-jwt-secret   # used to sign session tokens (V1)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# fastrr-checkout / fastrr-order-webhook
FASTRR_API_KEY=
FASTRR_SECRET_KEY=

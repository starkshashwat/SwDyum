{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "ui_kits/frontend-v2/**",
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Poppins|Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Poppins, Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: title, children, defaultOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:bestseller|spicy|new)$/]",
        "message": "<Badge> tone must be one of 'bestseller' | 'spicy' | 'new'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|children|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, children, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|text)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryCardData'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|image|key|ref|className|style|children)$/]",
        "message": "<CategoryCardData> doesn't accept that prop. Declared props: title, subtitle, image."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|subtitle|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: icon, title, subtitle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: variant, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lotus|fish|sun|floral)$/]",
        "message": "<Divider> variant must be one of 'lotus' | 'fish' | 'sun' | 'floral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|active|filled|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, active, filled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|placeholder|value|onChange|prefix|rightSlot|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, placeholder, value, onChange, prefix, rightSlot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|children|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, children, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='OtpInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:length|value|onChange|key|ref|className|style|children)$/]",
        "message": "<OtpInput> doesn't accept that prop. Declared props: length, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:price|oldPrice|unit|key|ref|className|style|children)$/]",
        "message": "<PriceBlock> doesn't accept that prop. Declared props: price, oldPrice, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCardData'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|image|price|oldPrice|rating|reviewsCount|tagline|badge|key|ref|className|style|children)$/]",
        "message": "<ProductCardData> doesn't accept that prop. Declared props: name, image, price, oldPrice, rating, reviewsCount, tagline, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCardData'] > JSXAttribute[name.name='badge'] > Literal[value!=/^(?:bestseller|spicy|new)$/]",
        "message": "<ProductCardData> badge must be one of 'bestseller' | 'spicy' | 'new'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuantitySelector'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|min|key|ref|className|style|children)$/]",
        "message": "<QuantitySelector> doesn't accept that prop. Declared props: value, onChange, min."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|subtitle|align|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, subtitle, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeading> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: key, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:rating|count|size|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: rating, count, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|icon|visible|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: message, icon, visible."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
